DATABASE_URL=postgres://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com

# Used to validate preview requests
PREVIEW_SECRET=PAYLOAD_PREVIEW_SECRET_HERE

# Vercel Blob Storage (for media uploads)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# AI SEO: auto-fill meta title/description on Page create (optional)
OPENAI_API_KEY=OPENAI_API_KEY

# OIDC SSO (Auth0, Keycloak, Okta, etc.)
OIDC_ISSUER=https://your-tenant.auth0.com
OIDC_CLIENT_ID=your_client_id
OIDC_CLIENT_SECRET=your_client_secret
# Optional; default: NEXT_PUBLIC_SERVER_URL + /api/auth/oidc/callback
OIDC_REDIRECT_URI=https://yourdomain.com/api/auth/oidc/callback
# Optional; default: openid profile email
OIDC_SCOPES=openid profile email
# Optional; recommended for Auth0
OIDC_USE_PKCE=true
# Optional; label on login button (e.g. Auth0). For client: NEXT_PUBLIC_OIDC_PROVIDER_NAME
OIDC_PROVIDER_NAME=Auth0
NEXT_PUBLIC_OIDC_PROVIDER_NAME=Auth0
